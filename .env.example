# Database Configuration (Neon DB - PostgreSQL)
DATABASE_URL=postgresql://user:password@your-neon-db-host.neon.tech/eluminate_db

# Hugging Face Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Twitter API (using TwitterAPI.io or similar)
TWITTER_API_KEY=your_twitter_api_key_here

# App Settings
APP_ENV=development

# JWT
JWT_SECRET=your-super-secret-key-here

# SMTP (Gmail example — use App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com
